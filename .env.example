# ─────────────────────────────────────────────────────────────
#  Plavih Hotel Academy — Variables de entorno
#  Copia este archivo a .env.local y completa los valores reales.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Obtén estas credenciales en: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Solo para operaciones server-side privilegiadas. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Modo demo ─────────────────────────────────────────────────
# true  → usa datos mock, no necesita Supabase (desarrollo sin backend)
# false → requiere Supabase configurado (staging y producción)
# Sin este valor en producción → comportamiento real (equivale a false)
NEXT_PUBLIC_USE_MOCKS=true

# ── IA (Fase 3) ───────────────────────────────────────────────
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Correo transaccional (Fase 3) ─────────────────────────────
# RESEND_API_KEY=your-resend-api-key
# FROM_EMAIL=noreply@plavih.com
